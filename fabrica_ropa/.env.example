# ============================================================================
# Configuración del proveedor LLM
# ============================================================================
# Opciones soportadas (cualquier endpoint compatible con OpenAI):
#
#   GitHub Models (RECOMENDADO - free tier generoso, gpt-4o-mini gratis):
#       LLM_PROVIDER=github
#       LLM_MODEL=openai/gpt-4o-mini
#       LLM_API_BASE=https://models.github.ai/inference
#       LLM_API_KEY=ghp_xxxxxxxxx   ← Tu Personal Access Token de GitHub
#
#   Google Gemini (free tier limitado, 15 req/min):
#       LLM_PROVIDER=gemini
#       LLM_MODEL=gemini/gemini-2.0-flash
#       LLM_API_BASE=
#       LLM_API_KEY=AIza...   ← Tu Gemini API key
#
#   OpenAI directo:
#       LLM_PROVIDER=openai
#       LLM_MODEL=openai/gpt-4o-mini
#       LLM_API_BASE=https://api.openai.com/v1
#       LLM_API_KEY=sk-...
# ============================================================================

LLM_PROVIDER=github
LLM_API_KEY=pega_tu_token_aqui
LLM_MODEL=openai/gpt-4o-mini
LLM_API_BASE=https://models.github.ai/inference

# ============================================================================
# Modo de ejecución
# ============================================================================
# real = consulta al LLM (necesita LLM_API_KEY válido)
# mock = sin LLM, usa heurísticas (útil cuando no hay cuota o internet)
EXECUTION_MODE=real

# ============================================================================
# Persistencia (rutas relativas a la carpeta del proyecto)
# ============================================================================
DB_PATH=./data/pedidos.db
EMAILS_OUTPUT_DIR=./data/emails_generados
